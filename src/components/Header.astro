---
const path = Astro.url.pathname;
const onLearn = path === "/learn" || path.startsWith("/learn/");
---
<header class="sticky top-0 z-20 border-b border-slate-200 bg-white/85 backdrop-blur supports-[backdrop-filter]:bg-white/70 dark:border-slate-800 dark:bg-slate-950/85">
  <div class="h-0.5 w-full bg-accent-600"></div>
  <nav aria-label="Site" class="mx-auto flex max-w-5xl items-center justify-between px-4 py-3">
    <a href="/" class="text-base font-bold tracking-tight text-slate-900 dark:text-slate-100">Agentic Learning</a>
    <a
      href="/learn"
      aria-current={onLearn ? "page" : undefined}
      class="rounded-[var(--radius-md)] px-3 py-1.5 text-sm font-medium text-slate-600 hover:bg-slate-100 hover:text-slate-900 aria-[current=page]:bg-accent-50 aria-[current=page]:text-accent-700 dark:text-slate-300 dark:hover:bg-slate-800 dark:hover:text-white dark:aria-[current=page]:bg-accent-950 dark:aria-[current=page]:text-accent-200"
    >
      Curriculum
    </a>
  </nav>
</header>
