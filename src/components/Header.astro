---
const path = Astro.url.pathname;
const onLearn = path === "/learn" || path.startsWith("/learn/");
---
<header class="border-b border-gray-200 dark:border-gray-800">
  <nav aria-label="Site" class="mx-auto flex max-w-5xl items-center justify-between px-4 py-3">
    <a href="/" class="font-semibold">Agentic Learning</a>
    <a
      href="/learn"
      aria-current={onLearn ? "page" : undefined}
      class="text-sm underline"
    >
      Curriculum
    </a>
  </nav>
</header>
