---
import BaseLayout from "./BaseLayout.astro";
import Sidebar from "../components/Sidebar.astro";
import MarkComplete from "../components/MarkComplete.tsx";
import Quiz from "../components/Quiz.tsx";
import TrackVisit from "../components/TrackVisit.tsx";
import type { Curriculum, LessonMeta, Adjacent } from "../lib/curriculum";

interface Props {
  lesson: LessonMeta;
  curriculum: Curriculum;
  adjacent: Adjacent;
}
const { lesson, curriculum, adjacent } = Astro.props;
---
<BaseLayout title={lesson.title}>
  <div class="grid grid-cols-1 gap-10 md:grid-cols-[17rem_1fr]">
    <aside class="md:sticky md:top-20 md:max-h-[calc(100vh-6rem)] md:overflow-y-auto md:border-r md:border-slate-200 md:pr-5 md:dark:border-slate-800">
      <Sidebar curriculum={curriculum} currentSlug={lesson.slug} />
    </aside>
    <article class="prose prose-slate max-w-none dark:prose-invert prose-pre:bg-slate-900 prose-pre:text-slate-100 prose-code:font-mono prose-headings:tracking-tight prose-a:text-accent-700 dark:prose-a:text-accent-300">
      <TrackVisit client:load slug={lesson.slug} />
      <p class="badge">
        {lesson.type} · {lesson.estMinutes} min
      </p>
      <h1>{lesson.title}</h1>
      {lesson.type === "quiz" ? (
        <Quiz
          client:load
          slug={lesson.slug}
          title={lesson.title}
          questions={lesson.questions ?? []}
        />
      ) : lesson.type === "reading" || lesson.type === "interactive" ? (
        <slot />
      ) : (
        <p role="status">Unsupported lesson type: {lesson.type}</p>
      )}
      <div class="mt-10 not-prose">
        <MarkComplete client:load slug={lesson.slug} />
      </div>
      <nav
        aria-label="Lesson navigation"
        class="mt-14 flex justify-between gap-4 border-t border-slate-200 pt-6 text-sm dark:border-slate-800"
      >
        {adjacent.prev ? (
          <a href={`/learn/${adjacent.prev.slug}`} class="card link-accent px-4 py-3 font-medium no-underline hover:shadow-[var(--shadow-raise)]">← {adjacent.prev.title}</a>
        ) : <span />}
        {adjacent.next ? (
          <a href={`/learn/${adjacent.next.slug}`} class="card link-accent px-4 py-3 font-medium no-underline hover:shadow-[var(--shadow-raise)]">{adjacent.next.title} →</a>
        ) : <span />}
      </nav>
    </article>
  </div>
</BaseLayout>
